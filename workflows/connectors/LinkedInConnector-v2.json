      "parameters": {
        "jsCode": "// Étape 3: Vérifier Creative + Activer Campaign\n// FIX F8: Utiliser PATCH endpoint au lieu de POST\nconst resp = $input.first().json;\nconst prev = $('PAID 2 — Check Campaign + Prép Creative').first().json;\nconst headers = resp.headers || {};\n\nconst li_creative_id = headers['x-restli-id'] || resp.id || null;\nif (!li_creative_id) {\n  return [{ json: {\n    ...prev, _step_ok: false,\n    _error_code: 'LI_CREATIVE_FAILED',\n    _error_message: JSON.stringify(resp.error || resp).substring(0, 500),\n    _orphans: prev._orphans\n  } }];\n}\n\nreturn [{ json: {\n  ...prev,\n  _li_creative_id: li_creative_id,\n  _step_ok: true,\n  _step: 'ACTIVATE',\n  // FIX F8: Endpoint pour PATCH (activation via partial update)\n  _endpoint: `https://api.linkedin.com/rest/adCampaigns/${prev._li_campaign_id}`,\n  _body: { status: 'ACTIVE', patch: { '$set': { status: 'ACTIVE' } } }\n} }];"
