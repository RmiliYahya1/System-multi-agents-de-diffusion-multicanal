        "jsCode": "// Finaliser le post body avec l'image URN réel\nconst d = $('Extraire Upload URL + URN').first().json;\nconst postBody = { ...d._post_body };\nif (postBody.content?.media) {\n  postBody.content.media.id = d._image_urn;\n}\n\nreturn [{ json: {\n  ...d,\n  _endpoint: 'https://api.linkedin.com/rest/posts',\n  _body: postBody\n}}];"
