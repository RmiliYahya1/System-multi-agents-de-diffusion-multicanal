    {
      "parameters": {
        "jsCode": "// LI PAID — Étape 1: Créer Campaign\nconst d = $('Initialiser Connecteur').first().json;\nconst ads = d.payload.ads || {};\nconst pp = d.payload.platform_params;\n\nconst campaignBody = {\n  account: pp.ad_account_urn || `urn:li:sponsoredAccount:${pp.account_id || '0'}`,\n  name: `${d.job.campaign_id || 'Campaign'} — LINKEDIN — ${d.job_id}`,\n  type: ads.campaign_params?.campaign_type || 'SPONSORED_CONTENT',\n  objectiveType: ads.campaign_params?.objective || 'WEBSITE_VISITS',\n  status: 'PAUSED',\n  costType: 'CPM',\n  dailyBudget: {\n    amount: String(d.job.budget_amount || 100),\n    currencyCode: d.job.budget_currency || 'MAD'\n  },\n  targetingCriteria: ads.adset_params?.targeting || {},\n  locale: { country: 'MA', language: 'fr' }\n};\n\nif (d.job.scheduled_at) {\n  campaignBody.runSchedule = { start: new Date(d.job.scheduled_at).getTime() };\n}\n\nreturn [{ json: {\n  ...d,\n  _step_ok: true,\n  _step: 'CAMPAIGN',\n  _endpoint: 'https://api.linkedin.com/rest/adCampaigns',\n  _body: campaignBody,\n  _orphans: {}\n} }];"
      },
