    {
      "parameters": {
        "jsCode": "const resp = $input.first().json;\nconst prev = $('Construire Post LI ORGANIC').first().json;\nconst headers = resp.headers || {};\n\n// LinkedIn retourne 201 avec x-restli-id\nconst postUrn = headers['x-restli-id'] || headers['x-linkedin-id'] || resp.id || null;\n\nif (postUrn) {\n  return [{ json: {\n    _success: true,\n    _platform_post_id: postUrn,\n    _status: 'PUBLISHED',\n    _error_code: null,\n    _error_message: null,\n    _orphans: {},\n    job_id: prev.job_id,\n    correlation_id: prev.correlation_id\n  } }];\n}\n\n// Vérifier si c'est une erreur\nconst errBody = resp.error || resp;\nconst errMsg = typeof errBody === 'object' ? JSON.stringify(errBody) : String(errBody);\nreturn [{ json: {\n  _success: false,\n  _status: 'FAILED_PUBLICATION',\n  _error_code: 'LI_POST_FAILED',\n  _error_message: errMsg.substring(0, 500),\n  _orphans: {},\n  job_id: prev.job_id,\n  correlation_id: prev.correlation_id\n} }];"
      },
