      "parameters": {
        "jsCode": "const resp = $input.first().json;\nconst prev = $('PAID 3 — Check Creative + Prép Activation').first().json;\n\n// LinkedIn PATCH retourne 204 No Content en cas de succès\nconst isError = resp.error || (resp.status && resp.status >= 400);\nif (isError) {\n  return [{ json: {\n    ...prev, _step_ok: false,\n    _error_code: 'LI_ACTIVATION_FAILED',\n    _error_message: JSON.stringify(resp.error || resp).substring(0, 500)\n  } }];\n}\n\nreturn [{ json: { ...prev, _step_ok: true } }];"
