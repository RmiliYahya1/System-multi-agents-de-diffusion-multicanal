    {
      "parameters": {
        "jsCode": "// LI ORGANIC — Construire le post (UC-03 §6.5)\nconst d = $('Initialiser Connecteur').first().json;\nconst content = d.payload.content;\nconst pp = d.payload.platform_params;\nconst author_urn = pp.author_urn;\nconst visibility = pp.visibility || 'PUBLIC';\n\nlet commentary = content.text || '';\nif (content.hashtags && Array.isArray(content.hashtags) && content.hashtags.length > 0) {\n  commentary += '\\n\\n' + content.hashtags.join(' ');\n}\n\nconst postBody = {\n  author: author_urn,\n  commentary,\n  visibility,\n  distribution: { feedDistribution: 'MAIN_FEED', targetEntities: [], thirdPartyDistributionChannels: [] },\n  lifecycleState: 'PUBLISHED'\n};\n\nconst hasMedia = content.media && content.media.length > 0;\nif (hasMedia) {\n  // Placeholder — sera remplacé après upload\n  postBody.content = {\n    media: {\n      title: content.media[0].alt_text || 'Media',\n      id: 'PLACEHOLDER_MEDIA_URN'\n    }\n  };\n}\n\nif (!hasMedia && content.link?.url) {\n  postBody.content = {\n    article: {\n      source: content.link.url,\n      title: content.headline || content.text?.substring(0, 70) || '',\n      description: content.description || ''\n    }\n  };\n}\n\nreturn [{ json: {\n  ...d,\n  _has_media: hasMedia,\n  _media_url: hasMedia ? content.media[0].url : null,\n  _post_body: postBody,\n  _author_urn: author_urn\n}}];"
      },
