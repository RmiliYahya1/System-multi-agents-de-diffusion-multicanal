    {
      "parameters": {
        "jsCode": "// Étape 2: Vérifier Campaign + Créer Creative\nconst resp = $input.first().json;\nconst prev = $('PAID 1 — Prép Campaign LI').first().json;\nconst headers = resp.headers || {};\n\nconst li_campaign_id = headers['x-restli-id'] || resp.id || null;\nif (!li_campaign_id) {\n  return [{ json: {\n    ...prev, _step_ok: false,\n    _error_code: 'LI_CAMPAIGN_FAILED',\n    _error_message: JSON.stringify(resp.error || resp).substring(0, 500),\n    _orphans: {}\n  } }];\n}\n\nconst content = prev.payload.content;\nconst pp = prev.payload.platform_params;\n\nconst creativeBody = {\n  campaign: `urn:li:sponsoredCampaign:${li_campaign_id}`,\n  reference: pp.author_urn || 'urn:li:organization:0',\n  intendedStatus: 'ACTIVE',\n  type: 'SPONSORED',\n  variables: {\n    data: {\n      'com.linkedin.ads.SponsoredUpdateCreativeVariables': {\n        activity: '',\n        directSponsoredContent: {\n          share: {\n            commentary: content.text || '',\n            shareMediaCategory: 'ARTICLE',\n            media: [{\n              status: 'READY',\n              originalUrl: content.link?.url || '',\n              title: { text: content.headline || '' },\n              description: { text: content.description || '' }\n            }]\n          }\n        }\n      }\n    }\n  }\n};\nif (pp.cta_type) creativeBody.callToAction = { labelType: pp.cta_type };\n\nreturn [{ json: {\n  ...prev,\n  _li_campaign_id: li_campaign_id,\n  _orphans: { li_campaign_id },\n  _step_ok: true,\n  _step: 'CREATIVE',\n  _endpoint: 'https://api.linkedin.com/rest/creatives',\n  _body: creativeBody\n} }];"
      },
