    {
      "parameters": {
        "jsCode": "// Extraire l'image URN et l'upload URL\nconst resp = $input.first().json;\nconst prev = $('Construire Post LI ORGANIC').first().json;\nconst body = resp.value || resp;\n\nconst imageUrn = body.image || 'UPLOAD_FAILED';\nconst uploadUrl = body.uploadUrl || '';\n\nif (!uploadUrl) {\n  return [{ json: {\n    _success: false,\n    _status: 'FAILED_PUBLICATION',\n    _error_code: 'LI_UPLOAD_INIT_FAILED',\n    _error_message: 'LinkedIn initializeUpload n\\'a pas retourné d\\'uploadUrl',\n    _orphans: {},\n    job_id: prev.job_id,\n    correlation_id: prev.correlation_id\n  } }];\n}\n\nreturn [{ json: {\n  ...prev,\n  _image_urn: imageUrn,\n  _upload_url: uploadUrl,\n  _upload_ok: true\n}}];"
